entrypoint = "main.py"
modules = ["python-3.11"]

[nix]
channel = "stable-25_05"
packages = ["gcc", "glibcLocales", "libgcc", "ocl-icd", "opencl-headers", "patchelf"]

[unitTest]
language = "python3"

[gitHubImport]
requiredFiles = [".replit", "replit.nix"]

[deployment]
run = ["python3", "main.py"]
deploymentTarget = "cloudrun"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Fixed Stages Runner"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Historical Extract"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python dashboard/server.py"
waitForPort = 5000

[[workflows.workflow]]
name = "Fixed Stages Runner"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python run_fixed_stages.py --only anomaly"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Historical Extract"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python run_historical_extract.py 2"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80
