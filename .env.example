# ============================================================
# partswatch-ai — Environment Variable Template
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ============================================================

# --- Supabase ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# Direct PostgreSQL URI — needed for DDL (db_setup.py).
# Find in Supabase → Project Settings → Database → Connection string (URI mode).
# Replace [YOUR-PASSWORD] with your database password.
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[project-id].supabase.co:5432/postgres

# --- Anthropic (Claude API) ---
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Open-Meteo (no key needed — free public API) ---
# NE Ohio coordinates (Cleveland)
WEATHER_LAT=41.4993
WEATHER_LON=-81.6944

# --- Application Settings ---
LOG_LEVEL=INFO
ENVIRONMENT=development   # development | production
